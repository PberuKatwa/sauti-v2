<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ardhitech Inquiry</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
</head>

<body style="margin:0; padding:0; background:#F5F4F0; font-family:'DM Sans', Arial, sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#F5F4F0; padding:60px 20px;">
<tr>
<td align="center">

<table width="560" cellpadding="0" cellspacing="0" style="background:#FFFFFF;">

<!-- Top Accent -->
<tr>
<td style="background:#C0182A; height:3px;"></td>
</tr>

<!-- Header -->
<tr>
<td style="padding:40px 48px 24px 48px; text-align:center;">

<img src="{{logoUrl}}" width="110" style="margin-bottom:18px; opacity:0.9;" />

<p style="
margin:0;
font-family:'DM Sans', Arial;
font-size:11px;
letter-spacing:0.18em;
text-transform:uppercase;
color:#A8A89A;
">
New Client Inquiry
</p>

</td>
</tr>

<!-- Divider -->
<tr>
<td style="padding:0 48px;">
<div style="height:1px; background:#ECE9E2;"></div>
</td>
</tr>

<!-- Body -->
<tr>
<td style="padding:40px 48px;">

<p style="
margin:0 0 16px 0;
font-family:'Cormorant Garamond', Georgia, serif;
font-size:24px;
font-weight:400;
color:#1A1A17;
">
New Inquiry Received
</p>

<p style="
margin:0 0 30px 0;
font-size:14px;
line-height:1.8;
color:#4A4A42;
">
A prospective client has submitted a request through the Ardhitech platform. The inquiry details are presented below.
</p>

<!-- Inquiry Card -->
<table width="100%" cellpadding="0" cellspacing="0" style="background:#FAF9F6; border:1px solid #ECE9E2;">
<tr>
<td style="padding:28px 32px;">

<p style="
margin:0;
font-size:12px;
letter-spacing:0.12em;
text-transform:uppercase;
color:#9E9E8E;
margin-bottom:10px;
">
Inquiry Details
</p>

<div style="
font-size:14px;
line-height:1.9;
color:#3D3D35;
white-space:pre-line;
">
{{message}}
</div>

</td>
</tr>
</table>

</td>
</tr>

<!-- Signature -->
<tr>
<td style="padding:10px 48px 40px 48px;">

<p style="
margin:0 0 6px 0;
font-size:13px;
color:#6B6B61;
">
Submitted via:
</p>

<p style="
margin:0;
font-family:'Cormorant Garamond', serif;
font-size:18px;
color:#1A1A17;
letter-spacing:0.02em;
">
Ardhitech Consulting Platform
</p>

</td>
</tr>

<!-- Footer Divider -->
<tr>
<td style="padding:0 48px;">
<div style="height:1px; background:#ECE9E2;"></div>
</td>
</tr>

<!-- Footer -->
<tr>
<td style="padding:28px 48px 40px 48px;">

<table width="100%">
<tr>

<td style="font-size:10px; color:#AEAE9E; line-height:1.6;">
<strong style="letter-spacing:0.1em; text-transform:uppercase;">Ardhitech Consulting</strong><br>
Nairobi, Kenya · info@ardhitech.co.ke<br>
© {{year}} All rights reserved.
</td>

<td align="right">
<img src="{{logoUrl}}" width="80" style="opacity:0.6;" />
</td>

</tr>
</table>

</td>
</tr>

<!-- Bottom Accent -->
<tr>
<td style="background:#C0182A; height:2px;"></td>
</tr>

</table>

</td>
</tr>
</table>

</body>
</html>
